# ML Service Configuration
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://peakpurse_user:your_password_here@localhost:5432/peakpurse_dev

# Internal Authentication
INTERNAL_SECRET=your_internal_secret_here_change_in_production

# Backend Service
BACKEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# ML Model Configuration
MODEL_PATH=./models
MODEL_VERSION=1.0

# Feature Flags
ENABLE_HEALTH_SCORE=true
ENABLE_RECOMMENDATIONS=true
ENABLE_CATEGORIZER=true

# Performance
MAX_WORKERS=4
BATCH_SIZE=100

# Cache
CACHE_TTL=3600

# Monitoring
PROMETHEUS_ENABLED=true
METRICS_PORT=9090
