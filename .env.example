# PeakPurse Environment Configuration
# Copy this file to .env and update with your values

# Application Configuration
APP_ENV=development
APP_NAME=PeakPurse
APP_VERSION=1.0.0
APP_URL=http://localhost:3001

# Backend Configuration
BACKEND_URL=http://localhost:3000
BACKEND_PORT=3000

# Frontend Configuration
FRONTEND_URL=http://localhost:3001
FRONTEND_PORT=3001

# ML Service Configuration
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_PORT=8000

DATABASE_URL=postgresql://team_project_3qt9_user:lKlpvDKGJwted4kSeu6VYLolnBjCkkhv@dpg-d74kbv6uk2gs73a6u85g-a.singapore-postgres.render.com/team_project_3qt9

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Authentication & Security
JWT_SECRET=your_super_secure_jwt_secret_change_in_production
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here

# 2FA Configuration
TOTP_ISSUER=PeakPurse

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@peakpurse.com

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,csv,xls,xlsx

# External APIs
AA_BASE_URL=https://api.sandbox.accountaggregator.in
AA_CLIENT_ID=your_aa_client_id
AA_CLIENT_SECRET=your_aa_client_secret

# Queue Configuration
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# CORS Configuration
CORS_ORIGIN=http://localhost:3001,http://localhost:3000
CORS_CREDENTIALS=true

# Feature Flags
FEATURE_BENCHMARKING_ENABLED=true
FEATURE_ML_RECOMMENDATIONS_ENABLED=true
FEATURE_AA_INTEGRATION_ENABLED=false
FEATURE_CHATBOT_ENABLED=true

# Monitoring & Health
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true
PROMETHEUS_ENABLED=true

# Development
DEBUG=true
DEV_MODE=true

# Third-party Services
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_here
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
SENTRY_DSN=https://your_sentry_dsn_here

# Security Headers
HELMET_ENABLED=true
COMPRESSION_ENABLED=true

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# WebSocket Configuration
WEBSOCKET_ENABLED=true
WEBSOCKET_RECONNECT_ATTEMPTS=5
WEBSOCKET_RECONNECT_DELAY=1000

# Internal Service Communication
INTERNAL_SECRET=your_internal_service_secret_change_in_production
